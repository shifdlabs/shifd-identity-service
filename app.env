# ============================================================
# POSTGRES CONTAINER CONFIG
# These are read by the postgres Docker container on first run.
# POSTGRES_PASSWORD and DB_PASSWORD harus sama.
# ============================================================
POSTGRES_DB=shifd_identity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root1234

# ============================================================
# PGADMIN CONTAINER CONFIG
# Akses via http://localhost:5051
# Tambah server connection: host=postgres-sis, port=5432
# ============================================================
PGADMIN_DEFAULT_EMAIL=admin@shifd.com
PGADMIN_DEFAULT_PASSWORD=admin123

# ============================================================
# APPLICATION CONFIG
# Dibaca oleh Go app. DB_PORT = host port dari docker-compose (6501).
# ============================================================

# App
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# Database — host port harus cocok dengan docker-compose (6501:5432)
DB_HOST=localhost
DB_PORT=6501
DB_NAME=shifd_identity
DB_USER=postgres
DB_PASSWORD=root1234
DB_SSLMODE=disable

# Redis — host port harus cocok dengan docker-compose (6381:6379)
REDIS_HOST=localhost
REDIS_PORT=6381

# JWT — RSA keys dalam format base64-encoded PEM
# Cara generate:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   macOS:  base64 -i private.pem | tr -d '\n'
#   Linux:  base64 -w 0 private.pem
# Setelah encode, copy hasilnya ke sini, lalu hapus file .pem
JWT_PRIVATE_KEY_
JWT_PUBLIC_KEY_
JWT_KEY_ID=sis-key-v1
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h
JWT_ISSUER=https://auth.shifd.com

# Email — Resend (https://resend.com)
RESEND_API_KEY=re_a4b44hJX_7EiCSaXsZPthuq7dbwW2cPgv
RESEND_FROM_EMAIL=noreply@shifdlabs.com
RESEND_FROM_NAME=Shifd Labs

# Security
MAX_FAILED_LOGINS=5
ACCOUNT_LOCK_DURATION_MINUTES=30
RATE_LIMIT_AUTH_PER_MIN=5
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Platform admin — email yang auto-set is_platform_admin=true saat register
# Comma-separated jika lebih dari satu
PLATFORM_ADMIN_EMAILS=sisadmin@shifdlabs.com
